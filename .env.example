# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
DISCORD_GUILD_ID=your_discord_server_guild_id_here

# Database Configuration (Railway will provide a volume path)
# For local development: src/database.sqlite (relative to project root)
# For Railway: /data/database.sqlite (if using volume mount)
DATABASE_PATH=src/database.sqlite

# Node Environment
NODE_ENV=production

# Optional: Google API Credentials (if using Google Sheets integration)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
